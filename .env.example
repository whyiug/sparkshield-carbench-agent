ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LOGURU_LEVEL=DEBUG
LOG_FORMAT=text
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Track 1 SparkShield release. Keep credentials in an untracked .env file.
AGENT_LLM=gemini/gemini-3.5-flash
AGENT_PROVIDER=gemini
AGENT_API_BASE=
AGENT_API_KEY=
AGENT_DEPLOYMENT=
AGENT_SERVICE_TIER=
AGENT_REASONING_EFFORT=
AGENT_TEMPERATURE=0
AGENT_STRUCTURED_OUTPUT_MODE=json_schema
AGENT_THINKING=false
AGENT_INTERLEAVED_THINKING=false
AGENT_ENABLE_CRITIC=false
AGENT_CRITIC_MODEL=
AGENT_CRITIC_PROVIDER=
AGENT_CRITIC_API_BASE=
AGENT_CRITIC_API_KEY=
AGENT_TIMEOUT_SECONDS=90
AGENT_MAX_RETRIES=2
AGENT_SOFT_MAX_STEPS=49
AGENT_MAX_USER_TURNS=24
AGENT_SESSION_TTL_SECONDS=1800
AGENT_MAX_SESSIONS=256

# Track 2 Cerebras direct executor.
CEREBRAS_API_KEY=
TRACK2_EXECUTOR_MODEL=gpt-oss-120b
TRACK2_EXECUTOR_REASONING_EFFORT=medium
TRACK2_CEREBRAS_SERVICE_TIER=
TRACK2_MAX_COMPLETION_TOKENS=1024
TRACK2_TEMPERATURE=
TRACK2_CEREBRAS_QUEUE_BACKOFF_SECONDS=60
TRACK2_CEREBRAS_QUEUE_BACKOFF_INITIAL_JITTER_RATIO=0.1
TRACK2_CEREBRAS_QUEUE_BACKOFF_SECOND_MIN_SECONDS=90
TRACK2_CEREBRAS_QUEUE_BACKOFF_SECOND_MAX_SECONDS=120
TRACK2_CEREBRAS_QUEUE_BACKOFF_CAP_MIN_SECONDS=180
TRACK2_CEREBRAS_QUEUE_BACKOFF_CAP_MAX_SECONDS=300
TRACK2_CEREBRAS_RATE_LIMIT_RETRY_BUFFER_SECONDS=1
CAR_BENCH_CEREBRAS_RATE_LIMIT_REPORT_DIR=/tmp/car-bench-rate-limit-reports
TRACK2_LLM_MALFORMED_RETRIES=1

# Track 2 planner/executor template.
TRACK2_PLANNER_MODEL=gpt-oss-120b
TRACK2_PLANNER_REASONING_EFFORT=high
TRACK2_PLANNER_TEMPERATURE=
TRACK2_PLANNER_MAX_COMPLETION_TOKENS=4096
