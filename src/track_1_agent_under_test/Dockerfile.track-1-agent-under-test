FROM ghcr.io/astral-sh/uv:python3.12-trixie-slim@sha256:3137a0b606f65a74ee0245f43dae219b09e8af98fc37fef20841cbceef35a646 AS python-deps

RUN adduser --disabled-password --gecos "" carbench \
    && mkdir -p /home/carbench/app /home/carbench/.cache/uv \
    && chown -R carbench:carbench /home/carbench/app /home/carbench/.cache/uv
USER carbench
WORKDIR /home/carbench/app

COPY --chown=carbench:carbench src/track_1_agent_under_test/production/pyproject.toml ./pyproject.toml
COPY --chown=carbench:carbench src/track_1_agent_under_test/production/uv.lock ./uv.lock

RUN uv sync --frozen --no-install-project --no-dev

FROM ghcr.io/astral-sh/uv:python3.12-trixie-slim@sha256:3137a0b606f65a74ee0245f43dae219b09e8af98fc37fef20841cbceef35a646

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && adduser --disabled-password --gecos "" carbench \
    && mkdir -p /home/carbench/app \
    && chown -R carbench:carbench /home/carbench/app
USER carbench
WORKDIR /home/carbench/app

COPY --from=python-deps --chown=carbench:carbench /home/carbench/app/.venv .venv
COPY --chown=carbench:carbench src/logging_utils.py src/tool_call_types.py src/turn_metrics.py ./
COPY --chown=carbench:carbench src/track_1_agent_under_test/server.py src/track_1_agent_under_test/car_bench_agent.py ./track_1_agent_under_test/
COPY --chown=carbench:carbench src/track_1_agent_under_test/car_guard ./track_1_agent_under_test/car_guard

ENV PYTHONPATH=/home/carbench/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    LITELLM_LOCAL_MODEL_COST_MAP=True

ENTRYPOINT [".venv/bin/python", "track_1_agent_under_test/server.py"]
CMD ["--host", "0.0.0.0"]
EXPOSE 8080
